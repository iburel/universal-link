# Copy this file to `.env` (same directory) and fill it in: `docker compose`
# reads it automatically. Put NO secret in it — the OIDC client is public.

# The server's public domain name — must resolve (A/AAAA) to this machine.
# Caddy obtains the TLS certificate for it. The clients' config.json will point to
# wss://<this-domain>/ws.
UNIVERSALLINK_DOMAIN=your-server.example.com

# OIDC issuer (Google) and client_id of the "Desktop application"-type
# OIDC client (see doc/server-deployment.md, step 1). No client_secret.
UNIVERSALLINK_OIDC_ISSUER=https://accounts.google.com
UNIVERSALLINK_OIDC_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
